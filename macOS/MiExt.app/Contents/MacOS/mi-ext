#!/bin/bash
# MiExt — macOS App Entry Point
# Drag files/folders onto app, or double-click to launch GUI.
# Auto-detects system language for UI (Chinese / English).
# NOTE: No 'set -e' — osascript dialogs return non-zero on user cancel,
#       which should be handled gracefully, not kill the script.

# ─── Python interpreter (managed 3.13.12 with Tk 9.0.3) ───
# System /usr/bin/python3 uses Tk 8.5.9 which has severe rendering bugs
# on macOS. Use managed Python which ships with modern Tk.
PYTHON3="/Users/tuyi/.workbuddy/binaries/python/versions/3.13.12/bin/python3"
# Fallback to system Python if managed version unavailable
[ -x "$PYTHON3" ] || PYTHON3="/usr/bin/python3"

# ─── Resolve paths ───
APP_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
GUI_SCRIPT="$APP_ROOT/Resources/gui.py"

# ─── Debug log ───
DEBUG_LOG="/tmp/miext-debug-$$.log"
log_debug() { echo "[$(date '+%H:%M:%S')] $*" >> "$DEBUG_LOG"; }
log_debug "=== MiExt started ==="
log_debug "PID: $$"
log_debug "Args: $*"
log_debug "APP_ROOT: $APP_ROOT"
log_debug "GUI_SCRIPT: $GUI_SCRIPT"

# ══════════════════════════════════
#  Mode 1: Double-click (no args) → Launch GUI
# ══════════════════════════════════
if [ $# -eq 0 ]; then
    log_debug "No args — launching GUI mode"
    if [ -f "$GUI_SCRIPT" ]; then
        log_debug "Starting gui.py via python3"
        exec "$PYTHON3" "$GUI_SCRIPT" 2>>"$DEBUG_LOG"
    else
        log_debug "ERROR: gui.py not found at $GUI_SCRIPT"
        osascript -e 'display dialog "无法找到图形界面文件。\n\n请重新安装 MiExt。" with title "MiExt" buttons {"好"} default button 1' >/dev/null 2>&1
        exit 1
    fi
fi

# ══════════════════════════════════
#  Mode 2: Drag-and-drop (with args) → Direct processing
# ══════════════════════════════════

# ─── Language detection ───
LANG_CODE=$(defaults read -g AppleLocale 2>/dev/null | cut -d_ -f1)
if [ "$LANG_CODE" = "zh" ]; then
    APP_NAME="MiExt"
    MSG_NO_PHOTOS="该文件夹中没有找到 MVIMG 开头的动态照片。\n\n提示：小米动态照片文件名以 MVIMG 开头。"
    MSG_NO_VALID_FILES="选中的文件中没有 MVIMG 动态照片。"
    MSG_ERROR="无法访问："
    MSG_PROCESS_ERROR="处理出错，请检查文件夹权限。"
    MSG_RESULT_TITLE="MiExt — 完成"
    MSG_SUCCESS="✅ 成功提取"
    MSG_FAILED="❌ 失败："
    MSG_SKIPPED="⏭️ 跳过（已有）："
    MSG_SAVED="视频已保存在原位置"
    MSG_SEGMENTS="段视频"
    MSG_OPEN_FOLDER="打开文件夹"
    MSG_CLOSE="关闭"
    MSG_OK="好"
else
    APP_NAME="MiExt"
    MSG_NO_PHOTOS="No MVIMG dynamic photos found in this folder.\n\nHint: Xiaomi dynamic photo filenames start with MVIMG."
    MSG_NO_VALID_FILES="No MVIMG files in selection."
    MSG_ERROR="Cannot access: "
    MSG_PROCESS_ERROR="Processing error. Please check folder permissions."
    MSG_RESULT_TITLE="MiExt — Done"
    MSG_SUCCESS="✅ Extracted"
    MSG_FAILED="❌ Failed: "
    MSG_SKIPPED="⏭️ Skipped (already exists): "
    MSG_SAVED="Videos saved in original location"
    MSG_SEGMENTS="video(s)"
    MSG_OPEN_FOLDER="Open Folder"
    MSG_CLOSE="Close"
    MSG_OK="OK"
fi

# ─── Python extraction script (embedded, passed via stdin) ───
PYTHON_SCRIPT='import sys, os, struct

MP4_MAGIC = b"ftyp"

def find_mp4_offset(filepath):
    with open(filepath, "rb") as f:
        offset = 0
        while True:
            data = f.read(65536)
            if not data:
                break
            pos = data.find(MP4_MAGIC)
            while pos != -1:
                if pos >= 4:
                    size = struct.unpack(">I", data[pos-4:pos])[0]
                    if 8 <= size <= 1000000:
                        return offset + pos - 4
                pos = data.find(MP4_MAGIC, pos + 1)
            offset += len(data)
    return None

def extract_video(input_path, output_path):
    offset = find_mp4_offset(input_path)
    if offset is None:
        return False
    video_size = os.path.getsize(input_path) - offset
    with open(input_path, "rb") as fin:
        fin.seek(offset)
        video_data = fin.read(video_size)
    with open(output_path, "wb") as fout:
        fout.write(video_data)
    return True
'

extract_folder() {
    local FOLDER="$1"
    local FULL_SCRIPT="$PYTHON_SCRIPT"'
FOLDER = sys.argv[1]
files = sorted(f for f in os.listdir(FOLDER) if f.upper().startswith("MVIMG") and f.lower().endswith((".jpg",".jpeg")))

if not files:
    print("EMPTY")
    sys.exit(0)

todo = []
skipped = []
for f in files:
    base = os.path.splitext(f)[0]
    if os.path.exists(os.path.join(FOLDER, base + ".mp4")):
        skipped.append(f)
    else:
        todo.append(f)

ok = fail = 0
for filename in todo:
    src = os.path.join(FOLDER, filename)
    dst = os.path.join(FOLDER, os.path.splitext(filename)[0] + ".mp4")
    if extract_video(src, dst):
        ok += 1
    else:
        fail += 1

print(f"OK:{ok}")
print(f"FAIL:{fail}")
print(f"SKIP:{len(skipped)}")
print(f"FOLDER:{FOLDER}")
print("MODE:folder")
'
    local OUTPUT
    OUTPUT=$("$PYTHON3" - "$FOLDER" <<< "$FULL_SCRIPT" 2>/dev/null)
    echo "$OUTPUT"
}

extract_files() {
    local FULL_SCRIPT="$PYTHON_SCRIPT"'
raw_files = sys.argv[1:]
valid = []
ignored = 0
for fpath in raw_files:
    name = os.path.basename(fpath)
    if name.upper().startswith("MVIMG") and name.lower().endswith((".jpg", ".jpeg")) and os.path.isfile(fpath):
        valid.append(fpath)
    else:
        ignored += 1

if ignored > 0:
    print(f"IGNORED:{ignored}")

if not valid:
    print("EMPTY")
    sys.exit(0)

from collections import defaultdict
groups = defaultdict(list)
for f in valid:
    groups[os.path.dirname(os.path.abspath(f))].append(f)

total_ok = total_fail = total_skip = 0
for folder, file_list in sorted(groups.items()):
    todo = []
    skipped = []
    for f in file_list:
        base = os.path.splitext(os.path.basename(f))[0]
        mp4_path = os.path.join(folder, base + ".mp4")
        if os.path.exists(mp4_path):
            skipped.append(f)
        else:
            todo.append((f, mp4_path))
    total_skip += len(skipped)
    for src, dst in todo:
        if extract_video(src, dst):
            total_ok += 1
        else:
            total_fail += 1

print(f"OK:{total_ok}")
print(f"FAIL:{total_fail}")
print(f"SKIP:{total_skip}")
print(f"FILES:{len(valid)}")
print("MODE:file")
'
    local OUTPUT
    OUTPUT=$("$PYTHON3" "$@" <<< "$FULL_SCRIPT" 2>/dev/null)
    echo "$OUTPUT"
}

# ─── OSA Script dialogs (drag-and-drop mode only) ───
show_alert() {
    local MSG="$1"
    local TITLE="${2:-$APP_NAME}"
    local BTNS="${3:-$MSG_OK}"
    osascript -e "display dialog \"$MSG\" with title \"$TITLE\" buttons {\"$BTNS\"} default button 1" >/dev/null 2>&1 || true
}

# ══════════════════════════════════
#  Main (drag-and-drop mode)
# ══════════════════════════════════

ARGS=("$@")
MODE=""
INPUTS=()

HAS_FILE=false
HAS_FOLDER=false
for ARG in "${ARGS[@]}"; do
    if [ -d "$ARG" ]; then
        HAS_FOLDER=true
        INPUTS+=("$ARG")
    elif [ -f "$ARG" ]; then
        HAS_FILE=true
        INPUTS+=("$ARG")
    fi
done

if $HAS_FILE && ! $HAS_FOLDER; then
    MODE="file"
elif $HAS_FOLDER; then
    if $HAS_FILE; then
        MODE="mixed"
    else
        MODE="folder"
    fi
fi

[ -z "$MODE" ] && { log_debug "No mode set, exiting"; exit 0; }
log_debug "Mode: $MODE, Inputs: ${INPUTS[*]}"

case "$MODE" in
    folder)
        FOLDER="${INPUTS[0]}"
        if [ ! -d "$FOLDER" ]; then
            show_alert "${MSG_ERROR}${FOLDER}" "$APP_NAME"; exit 1
        fi
        OUTPUT=$(extract_folder "$FOLDER")
        if echo "$OUTPUT" | grep -q "^EMPTY"; then
            show_alert "$MSG_NO_PHOTOS" "$APP_NAME"
        else
            OK=$(echo "$OUTPUT" | grep "^OK:" | cut -d: -f2)
            FAIL=$(echo "$OUTPUT" | grep "^FAIL:" | cut -d: -f2)
            SKIP=$(echo "$OUTPUT" | grep "^SKIP:" | cut -d: -f2)
            MSG="${MSG_SUCCESS}：${OK} ${MSG_SEGMENTS}\n${MSG_FAILED}${FAIL}\n${MSG_SKIPPED}${SKIP}\n\n${MSG_SAVED}"
            
            BTN=$(osascript -e "display dialog \"$MSG\" with title \"$MSG_RESULT_TITLE\" buttons {\"$MSG_CLOSE\", \"$MSG_OPEN_FOLDER\"} default button 2" 2>&1) || true
            if echo "$BTN" | grep -q "$MSG_OPEN_FOLDER\|,2"; then
                open "$FOLDER"
            fi
        fi
        ;;

    file)
        OUTPUT=$(extract_files "${INPUTS[@]}")
        if echo "$OUTPUT" | grep -q "^EMPTY"; then
            show_alert "$MSG_NO_VALID_FILES" "$APP_NAME"
        else
            OK=$(echo "$OUTPUT" | grep "^OK:" | cut -d: -f2)
            FAIL=$(echo "$OUTPUT" | grep "^FAIL:" | cut -d: -f2)
            SKIP=$(echo "$OUTPUT" | grep "^SKIP:" | cut -d: -f2)
            MSG="${MSG_SUCCESS}：${OK} ${MSG_SEGMENTS}\n${MSG_FAILED}${FAIL}\n${MSG_SKIPPED}${SKIP}\n\n${MSG_SAVED}"
            show_alert "$MSG" "$MSG_RESULT_TITLE"
        fi
        ;;

    mixed)
        ALL_OK=0; ALL_FAIL=0; ALL_SKIP=0; FIRST_FOLDER=""
        for ITEM in "${INPUTS[@]}"; do
            if [ -d "$ITEM" ]; then
                OUT=$(extract_folder "$ITEM")
                if ! echo "$OUT" | grep -q "^EMPTY"; then
                    ALL_OK=$((ALL_OK + $(echo "$OUT" | grep "^OK:" | cut -d: -f2)))
                    ALL_FAIL=$((ALL_FAIL + $(echo "$OUT" | grep "^FAIL:" | cut -d: -f2)))
                    ALL_SKIP=$((ALL_SKIP + $(echo "$OUT" | grep "^SKIP:" | cut -d: -f2)))
                    [ -z "$FIRST_FOLDER" ] && FIRST_FOLDER="$ITEM"
                fi
            fi
        done
        FILE_INPUTS=()
        for ITEM in "${INPUTS[@]}"; do
            [ -f "$ITEM" ] && FILE_INPUTS+=("$ITEM")
        done
        if [ ${#FILE_INPUTS[@]} -gt 0 ]; then
            OUT=$(extract_files "${FILE_INPUTS[@]}")
            if ! echo "$OUT" | grep -q "^EMPTY"; then
                ALL_OK=$((ALL_OK + $(echo "$OUT" | grep "^OK:" | cut -d: -f2)))
                ALL_FAIL=$((ALL_FAIL + $(echo "$OUT" | grep "^FAIL:" | cut -d: -f2)))
                ALL_SKIP=$((ALL_SKIP + $(echo "$OUT" | grep "^SKIP:" | cut -d: -f2)))
            fi
        fi
        MSG="${MSG_SUCCESS}：${ALL_OK} ${MSG_SEGMENTS}\n${MSG_FAILED}${ALL_FAIL}\n${MSG_SKIPPED}${ALL_SKIP}\n\n${MSG_SAVED}"
        
        BTN=$(osascript -e "display dialog \"$MSG\" with title \"$MSG_RESULT_TITLE\" buttons {\"$MSG_CLOSE\", \"$MSG_OPEN_FOLDER\"} default button 2" 2>&1) || true
        if echo "$BTN" | grep -q "$MSG_OPEN_FOLDER\|,2" && [ -n "$FIRST_FOLDER" ]; then
            open "$FIRST_FOLDER"
        fi
        ;;
esac

log_debug "=== MiExt finished normally ==="
