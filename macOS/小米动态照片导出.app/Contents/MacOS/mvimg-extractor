#!/bin/bash
# MVIMG Extractor.app — 原生 macOS 应用入口
# 拖拽文件夹到 App 图标，或双击后选择文件夹，自动提取动态照片视频

EXTRACTOR="/usr/bin/python3"  # 使用系统 Python 3.9

# ─── 内嵌提取脚本 ───
run_extraction() {
    local FOLDER="$1"
    /usr/bin/python3 - "$FOLDER" << 'PYEOF'
import sys, os, struct

MP4_MAGIC = b'ftyp'

def find_mp4_offset(filepath):
    with open(filepath, 'rb') as f:
        offset = 0
        while True:
            data = f.read(65536)
            if not data:
                break
            pos = data.find(MP4_MAGIC)
            while pos != -1:
                if pos >= 4:
                    size = struct.unpack('>I', data[pos-4:pos])[0]
                    if 8 <= size <= 1000000:
                        return offset + pos - 4
                pos = data.find(MP4_MAGIC, pos + 1)
            offset += len(data)
    return None

def extract_video(input_path, output_path):
    offset = find_mp4_offset(input_path)
    if offset is None:
        return False
    video_size = os.path.getsize(input_path) - offset
    with open(input_path, 'rb') as fin:
        fin.seek(offset)
        video_data = fin.read(video_size)
    with open(output_path, 'wb') as fout:
        fout.write(video_data)
    return True

FOLDER = sys.argv[1]
files = sorted(f for f in os.listdir(FOLDER)
               if f.upper().startswith('MVIMG') and f.lower().endswith(('.jpg','.jpeg')))

if not files:
    print("EMPTY")
    sys.exit(0)

todo = []
skipped = []
for f in files:
    base = os.path.splitext(f)[0]
    if os.path.exists(os.path.join(FOLDER, f"{base}.mp4")):
        skipped.append(f)
    else:
        todo.append(f)

ok = fail = 0
for filename in todo:
    src = os.path.join(FOLDER, filename)
    dst = os.path.join(FOLDER, os.path.splitext(filename)[0] + '.mp4')
    if extract_video(src, dst):
        ok += 1
    else:
        fail += 1

print(f"OK:{ok}")
print(f"FAIL:{fail}")
print(f"SKIP:{len(skipped)}")
print(f"FOLDER:{FOLDER}")
PYEOF
}

# ─── 通知 ───
notify() {
    osascript -e "display notification \"$1\" with title \"小米动态照片导出\" subtitle \"$2\""
}

# ─── 选择文件夹对话框 ───
pick_folder() {
    osascript -e '
        tell application "System Events"
            activate
            set folderPath to choose folder with prompt "选择包含 MVIMG 动态照片的文件夹："
            return POSIX path of folderPath
        end tell' 2>/dev/null
}

# ─── 结果对话框 ───
show_result() {
    local ok="$1"
    local fail="$2"
    local skip="$3"
    local folder="$4"

    osascript -e "
        display dialog \"✅ 成功提取：${ok} 段视频
❌ 失败：${fail}
⏭ 跳过（已有）：${skip}

视频已保存在原文件夹：
${folder}\" with title \"小米动态照片导出 — 完成\" buttons {\"打开文件夹\", \"关闭\"} default button 1" 2>/dev/null

    if [ $? -eq 0 ]; then
        open "$folder"
    fi
}

show_error() {
    osascript -e "display dialog \"$1\" with title \"小米动态照片导出\" buttons {\"好\"} with icon stop" 2>/dev/null
}

# ─── 主流程 ───
FOLDER=""

# 判断启动方式：拖拽文件到 App → 系统传参；双击打开 → 无参
if [ $# -ge 1 ]; then
    # 拖拽模式：取第一个参数（可能是文件或文件夹）
    FOLDER="$1"
    if [ -f "$FOLDER" ]; then
        FOLDER=$(dirname "$FOLDER")
    fi
else
    # 双击模式：弹出文件夹选择器
    FOLDER=$(pick_folder)
    if [ -z "$FOLDER" ]; then
        exit 0  # 用户取消
    fi
fi

if [ ! -d "$FOLDER" ]; then
    show_error "无法访问文件夹：$FOLDER"
    exit 1
fi

# 显示处理中提示（对话框稍后弹出结果即可，这里先静默处理）
RESULT=$(run_extraction "$FOLDER" 2>&1)
RC=$?

if echo "$RESULT" | grep -q "EMPTY"; then
    show_error "该文件夹中没有找到 MVIMG 开头的动态照片。\n\n提示：小米动态照片文件名以 MVIMG 开头。"
    notify "没有找到动态照片" "$FOLDER"
    exit 0
fi

if [ $RC -ne 0 ]; then
    show_error "处理出错，请检查文件夹权限。\n\n$RESULT"
    exit 1
fi

# 解析结果
OK=$(echo "$RESULT" | grep "^OK:" | cut -d: -f2)
FAIL=$(echo "$RESULT" | grep "^FAIL:" | cut -d: -f2)
SKIP=$(echo "$RESULT" | grep "^SKIP:" | cut -d: -f2)
FOLDER_NAME=$(echo "$RESULT" | grep "^FOLDER:" | cut -d: -f2)

show_result "${OK:-0}" "${FAIL:-0}" "${SKIP:-0}" "$FOLDER_NAME"
notify "成功 ${OK:-0} 段，跳过 ${SKIP:-0}" "$FOLDER_NAME"
