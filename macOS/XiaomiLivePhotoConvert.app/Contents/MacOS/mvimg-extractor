    MSG_CHOOSE_FILES="Select MVIMG dynamic photo files:"
    MSG_NO_PHOTOS="No MVIMG dynamic photos found in this folder.\n\nHint: Xiaomi dynamic photo filenames start with MVIMG."
    MSG_NO_VALID_FILES="No MVIMG files in selection."
    MSG_ERROR="Cannot access: "
    MSG_PROCESS_ERROR="Processing error. Please check folder permissions."
    MSG_NOTIFY_NONE="No dynamic photos found"
