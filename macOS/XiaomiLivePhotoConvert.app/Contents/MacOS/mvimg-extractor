    MSG_SKIP_SEG=", skipped "
fi

# ─── Embedded extraction script — FOLDER mode ───
run_extraction() {
    local FOLDER="$1"
    /usr/bin/python3 - "$FOLDER" << 'PYEOF'
import sys, os, struct

MP4_MAGIC = b'ftyp'

def find_mp4_offset(filepath):
    with open(filepath, 'rb') as f:
        offset = 0
        while True:
            data = f.read(65536)
            if not data:
                break
            pos = data.find(MP4_MAGIC)
            while pos != -1:
                if pos >= 4:
                    size = struct.unpack('>I', data[pos-4:pos])[0]
                    if 8 <= size <= 1000000:
                        return offset + pos - 4
                pos = data.find(MP4_MAGIC, pos + 1)
            offset += len(data)
    return None

def extract_video(input_path, output_path):
    offset = find_mp4_offset(input_path)
    if offset is None:
        return False
    video_size = os.path.getsize(input_path) - offset
    with open(input_path, 'rb') as fin:
        fin.seek(offset)
        video_data = fin.read(video_size)
    with open(output_path, 'wb') as fout:
        fout.write(video_data)
    return True

FOLDER = sys.argv[1]
files = sorted(f for f in os.listdir(FOLDER)
               if f.upper().startswith('MVIMG') and f.lower().endswith(('.jpg','.jpeg')))

if not files:
    print("EMPTY")
    sys.exit(0)

todo = []
skipped = []
for f in files:
    base = os.path.splitext(f)[0]
    if os.path.exists(os.path.join(FOLDER, f"{base}.mp4")):
        skipped.append(f)
    else:
        todo.append(f)

ok = fail = 0
for filename in todo:
    src = os.path.join(FOLDER, filename)
    dst = os.path.join(FOLDER, os.path.splitext(filename)[0] + '.mp4')
    if extract_video(src, dst):
        ok += 1
    else:
        fail += 1

print(f"OK:{ok}")
print(f"FAIL:{fail}")
print(f"SKIP:{len(skipped)}")
print(f"FOLDER:{FOLDER}")
print("MODE:folder")
PYEOF
}

# ─── Embedded extraction script — FILE mode ───
run_file_extraction() {
    # Pass file paths as arguments after --
    /usr/bin/python3 - "$@" << 'PYEOF'
import sys, os, struct

MP4_MAGIC = b'ftyp'

def find_mp4_offset(filepath):
    with open(filepath, 'rb') as f:
        offset = 0
        while True:
            data = f.read(65536)
            if not data:
                break
            pos = data.find(MP4_MAGIC)
            while pos != -1:
                if pos >= 4:
                    size = struct.unpack('>I', data[pos-4:pos])[0]
                    if 8 <= size <= 1000000:
                        return offset + pos - 4
                pos = data.find(MP4_MAGIC, pos + 1)
            offset += len(data)
    return None

def extract_video(input_path, output_path):
    offset = find_mp4_offset(input_path)
    if offset is None:
        return False
    video_size = os.path.getsize(input_path) - offset
    with open(input_path, 'rb') as fin:
        fin.seek(offset)
        video_data = fin.read(video_size)
    with open(output_path, 'wb') as fout:
        fout.write(video_data)
    return True

# Validate and filter MVIMG files
raw_files = sys.argv[1:]
valid = []
ignored = 0
for fpath in raw_files:
    name = os.path.basename(fpath)
    if name.upper().startswith('MVIMG') and name.lower().endswith(('.jpg', '.jpeg')) and os.path.isfile(fpath):
        valid.append(fpath)
    else:
        ignored += 1

if ignored > 0:
    print(f"IGNORED:{ignored}")

if not valid:
    print("EMPTY")
    sys.exit(0)

# Group by output directory
from collections import defaultdict
groups = defaultdict(list)
for f in valid:
    groups[os.path.dirname(os.path.abspath(f))].append(f)

total_ok = total_fail = total_skip = 0
for folder, file_list in sorted(groups.items()):
    todo = []
    skipped = []
    for f in file_list:
        base = os.path.splitext(os.path.basename(f))[0]
        mp4_path = os.path.join(folder, f"{base}.mp4")
        if os.path.exists(mp4_path):
            skipped.append(f)
        else:
            todo.append((f, mp4_path))

    total_skip += len(skipped)

    for src, dst in todo:
        if extract_video(src, dst):
            total_ok += 1
        else:
            total_fail += 1

print(f"OK:{total_ok}")
print(f"FAIL:{total_fail}")
print(f"SKIP:{total_skip}")
print(f"FILES:{len(valid)}")
print("MODE:file")
PYEOF
}

# ─── Notification ───
notify() {
    osascript -e "display notification \"$1\" with title \"$APP_NAME\" subtitle \"$2\""
}

# ─── Folder picker dialog ───
pick_folder() {
    osascript -e "
        tell application \"System Events\"
            activate
            set folderPath to choose folder with prompt \"$MSG_CHOOSE_FOLDER\"
            return POSIX path of folderPath
        end tell" 2>/dev/null
}

# ─── File picker dialog ───
pick_files() {
    osascript -e "
        tell application \"System Events\"
            activate
            set fileList to choose file with prompt \"$MSG_CHOOSE_FILES\" of type {\"public.image\", \"jpeg\", \"jpg\"} with multiple selections allowed
            set resultList to {}
            repeat with f in fileList
                copy POSIX path of f to end of resultList
            end repeat
            return resultList
        end tell" 2>/dev/null
}

# ─── Result dialog — folder mode ───
show_result_folder() {
    local ok="$1"
    local fail="$2"
    local skip="$3"
    local folder="$4"

    osascript -e "
        display dialog \"${MSG_SUCCESS}：${ok} ${MSG_SEGMENTS}
${MSG_FAILED}${fail}
${MSG_SKIPPED}${skip}

${MSG_SAVED}
${folder}\" with title \"$MSG_RESULT_TITLE\" buttons {\"$MSG_OPEN_FOLDER\", \"$MSG_CLOSE\"} default button 1" 2>/dev/null

    if [ $? -eq 0 ]; then
        open "$folder"
    fi
}

# ─── Result dialog — file mode ───
show_result_files() {
    local ok="$1"
    local fail="$2"
    local skip="$3"
    local file_count="$4"

    osascript -e "
        display dialog \"${MSG_SUCCESS}：${ok} ${MSG_SEGMENTS}
${MSG_FAILED}${fail}
${MSG_SKIPPED}${skip}

${MSG_SAVED}\"
         with title \"$MSG_RESULT_TITLE\" buttons {\"$MSG_CLOSE\"} default button 1" 2>/dev/null
}

show_error() {
    osascript -e "display dialog \"$1\" with title \"$APP_NAME\" buttons {\"$MSG_OK\"} with icon stop" 2>/dev/null
}

# ══════════════════════════════════
#  Main — dual mode: FILE vs FOLDER
# ══════════════════════════════════

MODE=""
INPUTS=()

if [ $# -ge 1 ]; then
    # Drag-and-drop mode: inspect dropped items
    HAS_FILE=0
    HAS_FOLDER=0

    for arg in "$@"; do
        if [ -f "$arg" ]; then
            HAS_FILE=1
            INPUTS+=("$arg")
        elif [ -d "$arg" ]; then
            HAS_FOLDER=1
            INPUTS+=("$arg")
        fi
    done

    # Determine primary mode based on what was dropped
    if [ $HAS_FILE -eq 1 ] && [ $HAS_FOLDER -eq 0 ]; then
        MODE="file"
    elif [ $HAS_FOLDER -eq 1 ]; then
        MODE="folder"
    elif [ $HAS_FILE -eq 1 ] && [ $HAS_FOLDER -eq 1 ]; then
        # Mixed: prioritize folder mode for folders, process files too
        MODE="mixed"
    fi
fi

if [ -z "$MODE" ]; then
    # Double-click mode: show picker
    CHOICE=$(osascript -e "
        tell application \"System Events\"
            activate
            set userChoice to display dialog \"请选择操作：\"
                with title \"$APP_NAME\"
                buttons {\"选择文件夹\", \"选择文件\", \"取消\"}
                default button 1
            return button returned of userChoice
        end tell" 2>/dev/null)

    case "$CHOICE" in
        "选择文件夹"|"Select Folder")
            FOLDER=$(pick_folder)
            if [ -n "$FOLDER" ]; then
                MODE="folder"
                INPUTS=("$FOLDER")
            else
                exit 0
            fi
            ;;
        "选择文件"|"Select Files")
            FILES=$(pick_files)
            if [ -n "$FILES" ]; then
                MODE="file"
                # Convert newlines to array
                while IFS= read -r f; do
                    INPUTS+=("$f")
                done <<< "$FILES"
            else
                exit 0
            fi
            ;;
        *)
            exit 0
            ;;
    esac
fi

# ═══ Execute ═══

case "$MODE" in
    "file")
        RESULT=$(run_file_extraction "${INPUTS[@]}" 2>&1)
        RC=$?
        ;;

    "folder")
        FOLDER="${INPUTS[0]}"
        if [ ! -d "$FOLDER" ]; then
            show_error "${MSG_ERROR}$FOLDER"
            exit 1
        fi
        RESULT=$(run_extraction "$FOLDER" 2>&1)
        RC=$?
        ;;

    "mixed")
        # Process all folders first, then files
        ALL_OK=0; ALL_FAIL=0; ALL_SKIP=0; FIRST_FOLDER=""
        for item in "${INPUTS[@]}"; do
            if [ -d "$item" ]; then
                SUB_RESULT=$(run_extraction "$item" 2>&1)
                OK=$(echo "$SUB_RESULT" | grep "^OK:" | cut -d: -f2)
                FAIL=$(echo "$SUB_RESULT" | grep "^FAIL:" | cut -d: -f2)
                SKIP=$(echo "$SUB_RESULT" | grep "^SKIP:" | cut -d: -f2)
                ALL_OK=$((ALL_OK + ${OK:-0}))
                ALL_FAIL=$((ALL_FAIL + ${FAIL:-0}))
                ALL_SKIP=$((ALL_SKIP + ${SKIP:-0}))
                if [ -z "$FIRST_FOLDER" ]; then
                    FIRST_FOLDER=$(echo "$SUB_RESULT" | grep "^FOLDER:" | cut -d: -f2-)
                fi
            fi
        done
        # Collect file inputs
        FILE_INPUTS=()
        for item in "${INPUTS[@]}"; do
            [ -f "$item" ] && FILE_INPUTS+=("$item")
        done
        if [ ${#FILE_INPUTS[@]} -gt 0 ]; then
            FILE_RESULT=$(run_file_extraction "${FILE_INPUTS[@]}" 2>&1)
            FOK=$(echo "$FILE_RESULT" | grep "^OK:" | cut -d: -f2)
            FFAIL=$(echo "$FILE_RESULT" | grep "^FAIL:" | cut -d: -f2)
            FSKIP=$(echo "$FILE_RESULT" | grep "^SKIP:" | cut -d: -f2)
            ALL_OK=$((ALL_OK + ${FOK:-0}))
            ALL_FAIL=$((ALL_FAIL + ${FFAIL:-0}))
            ALL_SKIP=$((ALL_SKIP + ${FSkip:-0}))
        fi
        show_result_folder "$ALL_OK" "$ALL_FAIL" "$ALL_SKIP" "${FIRST_FOLDER:-}"
        exit 0
        ;;
esac

# Parse results for file/folder modes
if echo "$RESULT" | grep -q "EMPTY"; then
    if [ "$MODE" = "file" ]; then
        show_error "$MSG_NO_VALID_FILES"
    else
        show_error "$MSG_NO_PHOTOS"
    fi
    notify "$MSG_NOTIFY_NONE" "$MODE"
    exit 0
fi

if [ $RC -ne 0 ]; then
    show_error "$MSG_PROCESS_ERROR\n\n$RESULT"
    exit 1
fi

OK=$(echo "$RESULT" | grep "^OK:" | cut -d: -f2)
FAIL=$(echo "$RESULT" | grep "^FAIL:" | cut -d: -f2)
SKIP=$(echo "$RESULT" | grep "^SKIP:" | cut -d: -f2)

IGNORED=$(echo "$RESULT" | grep "^IGNORED:" | cut -d: -f2)
if [ -n "$IGNORED" ] && [ "$IGNORED" -gt 0 ]; then
    echo "⚠️  ${MSG_IGNORED}${IGNORED}"
fi

# Show appropriate result dialog
CURRENT_MODE=$(echo "$RESULT" | grep "^MODE:" | cut -d: -f2)
if [ "$CURRENT_MODE" = "file" ]; then
    FILE_COUNT=$(echo "$RESULT" | grep "^FILES:" | cut -d: -f2)
    show_result_files "${OK:-0}" "${FAIL:-0}" "${SKIP:-0}" "${FILE_COUNT:-0}"
else
    FOLDER_NAME=$(echo "$RESULT" | grep "^FOLDER:" | cut -d: -f2-)
    show_result_folder "${OK:-0}" "${FAIL:-0}" "${SKIP:-0}" "$FOLDER_NAME"
fi

notify "${MSG_NOTIFY_DONE} ${OK:-0}${MSG_SKIP_SEG}${SKIP:-0}" "${MODE}"
