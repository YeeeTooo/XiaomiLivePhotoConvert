#!/bin/bash
# Xiaomi Live Photo Converter — macOS App entry point
# Drag files OR folders onto the app icon, or double-click to pick a folder.
# Auto-detects system language for UI (Chinese / English).

# ─── Language detection ───
LANG_CODE=$(defaults read -g AppleLocale 2>/dev/null | cut -d_ -f1)
if [ "$LANG_CODE" = "zh" ]; then
    APP_NAME="小米动态照片导出"
    MSG_CHOOSE_FOLDER="选择包含 MVIMG 动态照片的文件夹："
